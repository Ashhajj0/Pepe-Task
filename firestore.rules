rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.telegramId is number &&
             data.username is string && data.username.size() <= 100 &&
             data.first_name is string && (data.first_name is string || data.first_name == null) &&
             data.balance is number && data.balance >= 0 &&
             data.pendingWithdrawalBalance is number && data.pendingWithdrawalBalance >= 0;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny([
          'balance', 'pendingWithdrawalBalance', 'lastWithdrawalAt', 
          'adsWatchedToday', 'tasksCompleted', 'xp', 'level', 
          'levelProgress', 'lastLogin', 'preferredCurrency',
          'totalAdRewards', 'adCooldownUntil', 'lastDailyReset', 
          'referralEarnings', 'totalReferrals'
        ])
      )) || isAdmin();
    }

    // Withdrawal Validation
    function isValidWithdrawal(data) {
      return data.userId is string &&
             data.telegramUsername is string && data.telegramUsername.size() <= 100 &&
             data.withdrawalMethod in ['BEP20', 'BinanceID'] &&
             data.walletAddressOrBinanceId is string && data.walletAddressOrBinanceId.size() <= 200 &&
             data.amount is number && data.amount >= 8000 &&
             data.status in ['pending', 'approved', 'rejected', 'completed'] &&
             (data.createdAt == request.time || isAdmin());
    }

    match /withdrawals/{withdrawalId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidWithdrawal(incoming()) && incoming().status == 'pending';
      
      allow update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read, write: if isSignedIn() || isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn(); // Need to check if exists for login
      allow read, write: if false; // Only manageable via console
    }

    match /adminLogs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isAdmin();
    }
  }
}
